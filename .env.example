# Strava API
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_WEBHOOK_VERIFY_TOKEN=paceforge-verify

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database (for docker-compose.prod.yml, uses internal hostname "db")
DATABASE_URL=postgresql+asyncpg://paceforge:your_postgres_password@db:5432/paceforge
POSTGRES_PASSWORD=your_postgres_password

# Redis (internal hostname "redis")
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# App
BASE_URL=https://paceforge.yourdomain.com
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=false
